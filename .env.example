APP_NAME=PeopleOps Agent Platform

OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
HR_POLICY_PDF=data/员工手册测试版.pdf
CHROMA_PERSIST_DIR=.chroma/policy
RAG_MANIFEST_PATH=.chroma/policy/manifest.json
RAG_CHUNK_SIZE=400
RAG_CHUNK_OVERLAP=40
RAG_TOP_K=3

ENTERPRISE_MODE=false
REQUIRE_ACCESS_PASSWORD=false
ACCESS_PASSWORD=
ACCESS_PASSWORD_MIN_LENGTH=12
APP_DB_PATH=.runtime/peopleops.sqlite3
AUDIT_LOG_PATH=.runtime/audit/events.jsonl
AUDIT_LOG_MAX_BYTES=5000000
AUDIT_HASH_CHAIN_ENABLED=true
API_RATE_LIMIT_PER_MINUTE=120
DEFAULT_TENANT_ID=default
DEFAULT_ORG_ID=default-org
DEFAULT_DEPARTMENT_ID=peopleops
DATABASE_BACKEND=sqlite
VECTOR_BACKEND=chroma
OBJECT_STORAGE_URI=
APPROVAL_REQUIRED_ACTIONS=send_email,calendar_invite,ats_stage_change,offer_draft,rejection_draft
CONFIGURED_CONNECTOR_ENV=
EMAIL_DRAFT_DIR=.runtime/email_drafts
CALENDAR_DIR=.runtime/calendar
ATS_EXPORT_DIR=.runtime/ats_exports
TOOL_EXECUTION_MODE=local

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=hr@example.com
SMTP_USE_TLS=true

# Optional enterprise connector env markers; set CONFIGURED_CONNECTOR_ENV to the names present here.
WORKDAY_BASE_URL=
WORKDAY_CLIENT_ID=
BAMBOOHR_SUBDOMAIN=
BAMBOOHR_API_KEY=
GREENHOUSE_API_KEY=
LEVER_API_KEY=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
WECHAT_CORP_ID=
WECHAT_SECRET=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_TENANT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
